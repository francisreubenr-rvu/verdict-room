// PurchasePilot — Prisma schema (Postgres/Supabase)
// Schema mirrors PLAN.md §4 exactly. Do not diverge without updating the plan first.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase pgbouncer, port 6543) — used at runtime by the app.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) — used by Prisma Migrate/db push, which need a
  // non-pooled connection. Standard Supabase + Prisma setup pattern.
  directUrl = env("DIRECT_URL")
}

enum Platform {
  youtube
  reddit
  web
}

enum Sponsorship {
  organic
  sponsored
  affiliate
}

enum Sentiment {
  pro
  con
  neutral
}

enum Plan {
  free
  pro
}

// Tracks every URL discoverySources surfaced for a session, not just the ones that
// ended up as a linked Source — the audit trail behind the "every site we checked"
// transparency panel. "discovered" rows are overflow candidates past the plan's
// source cap, promoted to "dispatched" by the backfill step if earlier dispatches fail.
enum AttemptStatus {
  discovered
  dispatched
  succeeded
  failed
}

// One row per Supabase Auth user who has ever started a Stripe checkout. Absence of a row
// means "free, never subscribed" — see lib/billing.ts for the default-free lookup helper.
// SITE-REDESIGN-PLAN.md §Stage C: billing + quota only, no deep-dive/export/price-watch/queue.
model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique // Supabase Auth user id (auth.uid())
  plan                 Plan     @default(free)
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?
  status               String? // Stripe subscription status: active|past_due|canceled|... — or "comped" for a manual pro grant with no real Stripe subscription (see DEPLOY.md §h)
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ResearchSession {
  id              String   @id @default(cuid())
  userId          String                        // Supabase Auth user id (auth.uid()) — see §4a
  query           String
  parsed          Json                          // {product, useCase, budget}
  status          String   @default("queued")   // queued|searching|fetching|extracting|synthesizing|done|failed
  expectedSources Int      @default(0)          // set at end of Search step; process-source calls compare against this to detect "last one done"
  failureReason   String?                       // set only when status="failed" — query_parse_failed|search_unavailable|no_results|all_sources_failed|synthesis_failed|timed_out — see components/research-types.ts FailureReason
  verdictJson     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sources         SessionSource[]
  options         Option[]
  attempts        SourceAttempt[]

  @@index([userId])
}

// One row per URL discoverySources surfaced for a session — including ones that never
// got dispatched (overflow past the source cap) and ones that were dispatched but
// failed. Distinct from SessionSource, which only ever links successes.
model SourceAttempt {
  id            String        @id @default(cuid())
  sessionId     String
  session       ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url           String
  platform      Platform
  status        AttemptStatus @default(discovered)
  failureReason String?       // no_transcript|fetch_failed|blocked|extraction_error — set only on status="failed"
  sourceId      String?       // set once status="succeeded" — the resulting Source row
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([sessionId, url])
  @@index([sessionId])
}

// join table: many sessions can share one cached Source
model SessionSource {
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceId  String
  source    Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([sessionId, sourceId])
  @@index([sourceId])
}

model Source {
  id                String       @id @default(cuid())
  url               String       @unique   // cache key — fetched + extracted once per 30-day window
  platform          Platform
  author            String?
  sponsorship       Sponsorship?
  sponsorConfidence Float?
  summary           String?
  reviewDraft       String?      // youtube only — synthesized per-video review paragraph
  groundednessConfidence Float?  // youtube only — how well pain/good points are supported by the transcript
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt  // drives the 30-day freshness check in §3 step 2
  sessions          SessionSource[]
  findings          Finding[]
}

model Finding {
  id        String    @id @default(cuid())
  sourceId  String
  source    Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  option    String               // free-text; canonicalized into Option rows at synthesis time
  claim     String
  sentiment Sentiment
  quote     String
  createdAt DateTime  @default(now())

  @@index([sourceId])
}

model Option {
  id        String   @id @default(cuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  score     Float
  pros      String[]
  cons      String[]
  rank      Int
  createdAt DateTime @default(now())

  @@index([sessionId])
}
