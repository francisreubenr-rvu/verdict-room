# Copy to .env.local and fill in real values. Never commit .env.local.
# See PLAN.md §2 for the full secrets list and rationale.

# Anthropic Claude — used for search-query generation, extract+classify, and synthesis (M2+).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Custom Search API — search discovery (M2+). 100 queries/day on the free tier.
# Get these at https://programmablesearchengine.google.com/ (create a search engine for the CX,
# then enable the Custom Search API + get a key at https://console.cloud.google.com/apis/credentials)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# Supabase Postgres connection strings (Prisma). See prisma/schema.prisma — DATABASE_URL is the
# pooled (pgbouncer, port 6543) connection used at runtime; DIRECT_URL is the direct (port 5432)
# connection used by `prisma migrate`/`db push`. Both come from Supabase project settings ->
# Database -> Connection string.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres

# Reddit: no env vars needed. lib/research/fetch/reddit.ts uses Reddit's public, unauthenticated
# `<permalink>.json` endpoints rather than the OAuth2 client-credentials grant PLAN.md originally
# specified — deviation made to avoid the Reddit account/app-registration step entirely.

# Supabase project — public URL + anon key, safe to expose client-side (NEXT_PUBLIC_ prefix).
# From Supabase project settings -> API. Google OAuth Client ID/Secret are configured directly in
# the Supabase dashboard (Auth -> Providers -> Google), not read by this app as env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — Pro subscription billing. See DEPLOY.md §j for the manual dashboard steps
# (account, the $12/mo recurring Price, webhook endpoint + signing secret).
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
