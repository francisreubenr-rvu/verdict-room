# Copy to .env.local and fill in real values. Never commit .env.local.
# See PLAN.md §2 for the full secrets list and rationale.

# LLM provider — search-query generation, extract+classify, and synthesis (M2+). lib/llm.ts picks
# a provider by LLM_PROVIDER (default "groq"); a provider is used only when its key is also set.
# All are OpenAI-compatible (base-URL + key + model swap, same prompts).
LLM_PROVIDER=
#
# Groq (default) — fast LPU inference, openai/gpt-oss-120b. Free tier caps at 8000 tokens/min, which
# starves the large synthesis call once a session's extraction has drained the bucket.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Cerebras — fast inference (~1800 tok/s), llama-3.3-70b. Free tier: 30 req/min, 60K tokens/min
# (7.5x Groq's cap) and 1M tokens/day, so the synthesis call admits comfortably. No card. Get a key
# (csk-...) at https://cloud.cerebras.ai, then set LLM_PROVIDER=cerebras to use it.
CEREBRAS_API_KEY=
# NVIDIA NIM (build.nvidia.com) — wired up but its free-tier chat-completions endpoint returned no
# response for this account (hung the pipeline), so leave OFF unless re-confirmed. Enable with
# LLM_PROVIDER=nvidia + this key.
NVIDIA_API_KEY=

# Jina — search discovery (lib/research/search.ts, s.jina.ai) AND web content fetching
# (lib/research/fetch/web.ts, r.jina.ai) share this one key/token pool. Get one at
# https://jina.ai/api-dashboard/ (self-serve, no card required). Replaced Google Custom Search
# 2026-07-15 — see lib/research/search.ts for why.
JINA_API_KEY=

# Supabase Postgres connection strings (Prisma). See prisma/schema.prisma — DATABASE_URL is the
# pooled (Supavisor "Transaction pooler", port 6543) connection used at runtime; DIRECT_URL is
# used by `prisma db push`/migrate. Both come from Supabase project settings -> Database ->
# Connection string, SAME pooler host, different port/mode — do NOT use the raw "Direct
# connection" tab for DIRECT_URL. Confirmed live: that direct-connection host
# (db.<project-ref>.supabase.co) is IPv6-only, and fails with P1001 "Can't reach database server"
# on any network without outbound IPv6 (most home/ISP networks). Use "Session pooler" instead,
# which is IPv4-compatible:
#   DATABASE_URL ("Transaction pooler", port 6543):
#     postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL ("Session pooler", port 5432, same host as above):
#     postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-<n>-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Internal pipeline auth (added 2026-07-15 security review) — a shared secret the chained
# research-pipeline routes (process-source, synthesize) require on every internal hop, so they
# can't be called directly by anyone holding a session id. Generate with:
#   openssl rand -hex 32
# Required in every environment (local + Vercel) once set — in production, process-source/
# synthesize hard-fail with 500 if this is unset rather than silently running unauthenticated.
INTERNAL_PIPELINE_SECRET=

# Browserbase — real-browser Reddit fetch (lib/research/fetch/reddit-browserbase.ts). Changed
# 2026-07-16: Reddit deprecated unauthenticated `.json` access entirely on 2026-05-28 (every fetch
# now returns a flat 403), so a real browser session replaces the old plain-fetch approach. Get a
# key at https://www.browserbase.com — no BROWSERBASE_PROJECT_ID needed, the key alone resolves
# the project. Reliably beating Reddit's bot detection needs a plan with Proxies/Verified
# Sessions (Free tier doesn't include those) — a cost decision to make on Browserbase's dashboard.
BROWSERBASE_API_KEY=

# Supabase project — public URL + anon key, safe to expose client-side (NEXT_PUBLIC_ prefix).
# From Supabase project settings -> API. Google OAuth Client ID/Secret are configured directly in
# the Supabase dashboard (Auth -> Providers -> Google), not read by this app as env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — Pro subscription billing. See DEPLOY.md §j for the manual dashboard steps
# (account, the $12/mo recurring Price, webhook endpoint + signing secret).
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
